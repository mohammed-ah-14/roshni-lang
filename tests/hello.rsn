%% Test 10: Full integration program
%% Find the maximum number in a list

jalao isGreater (a, b) ->
  jab a > b ->
    wapas a
  warna
    wapas b
  end
end

dhara numbers = jama(3, 7, 1, 9, 4, 6, 2)
dikha "Fehrist:"
dikha numbers

dhara max = 0
dohra har numbers as n ->
   max = bulao isGreater max, n
end

dikha "Sab se bara number:"
dikha max